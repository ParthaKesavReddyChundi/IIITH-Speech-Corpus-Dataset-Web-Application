# ─────────────────────────────────────────────
# IIITH Speech Corpus Dataset Collection Platform
# Environment Variable Template
# Copy to .env.local and fill in all values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# From: Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — ONLY used in server-side API routes (never exposed to client)
# From: Supabase Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Sentry (Error Tracking) ───────────────────
# From: Sentry Project Settings → Client Keys
# Leave blank to disable Sentry in development
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Recording Limits ──────────────────────────
# Minimum recording duration in seconds
NEXT_PUBLIC_MIN_RECORDING_DURATION_S=0.5
# Maximum recording duration in seconds
NEXT_PUBLIC_MAX_RECORDING_DURATION_S=15

# ── Dataset Export ────────────────────────────
NEXT_PUBLIC_DATASET_LICENSE=CC BY 4.0
NEXT_PUBLIC_DATASET_INSTITUTION=IIIT Hyderabad
NEXT_PUBLIC_DATASET_NAME=IIITH Multilingual Speech Corpus

# ── App ───────────────────────────────────────
# Base URL of the deployment (no trailing slash)
# On Vercel this is auto-set via VERCEL_URL, but set here for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
